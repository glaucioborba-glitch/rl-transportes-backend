# Arquivo de configuração de ambiente para o projeto RL Transportes

# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:123456@localhost:5432/rl_transportes

# Segredos para JWT
JWT_SECRET=chave_secreta_jwt_acesso_aleatoria_gerada_123456789
JWT_REFRESH_SECRET=chave_secreta_jwt_refresh_aleatoria_gerada_987654321
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Porta da API
API_PORT=3000

# Ambiente
NODE_ENV=development
