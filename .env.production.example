# Variáveis de referência para deploy em produção (copiar para o segredo/plataforma de env).
# Não use valores reais de segredo aqui.

NODE_ENV=production

# Origens do front autorizadas (obrigatório em produção se CORS_ORIGIN não estiver definido no processo).
CORS_ORIGIN_PROD=https://portal.rltransportes.com

# Ou lista única explícita:
# CORS_ORIGIN=https://portal.rltransportes.com,https://app.rltransportes.com

AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_SECURE=1
SWAGGER_ENABLED=0
CSRF_ENABLED=1

# Front build:
# NEXT_PUBLIC_CSRF_ENABLED=1
# NEXT_PUBLIC_API_URL=https://api.rltransportes.com
