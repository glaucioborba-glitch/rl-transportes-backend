# Copie para .env na raiz do monorepo
#
# Com Docker (npm run docker:up na raiz): usuário postgres, senha 123456, DB rl_transportes — igual a este URL.

DATABASE_URL=postgresql://postgres:123456@localhost:5432/rl_transportes

JWT_SECRET=defina_um_segredo_longo
JWT_REFRESH_SECRET=defina_outro_segredo_longo
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# Swagger/OpenAPI: em produção permanece desligado salvo SWAGGER_ENABLED=1.
# SWAGGER_ENABLED=0
# Cookies HttpOnly para JWT (staff web). Requer CORS_ORIGIN com URL exata do front (porta incluída) e header X-RL-Auth-Cookie no login/refresh.
# AUTH_HTTP_ONLY_COOKIES=0
# AUTH_COOKIE_SECURE=1
# AUTH_COOKIE_SAMESITE=lax
# Tempos máx. dos cookies (ms), opcionais:
# AUTH_ACCESS_COOKIE_MAX_MS=3600000
# AUTH_REFRESH_COOKIE_MAX_MS=604800000

# Origens CORS (vírgula). Produção: domínio exato do portal / front.
# CORS_ORIGIN=https://app.empresa.com,https://portal.empresa.com
# TRUST_PROXY=1
# Recomendado atrás de reverse proxy / load balancer (X-Forwarded-For correto no rate limit).

# Limite global de pedidos por IP (default 100 / 15 min). Health check excluído da contagem.
# RATE_LIMIT_MAX=100

# Redis (rate limit login, cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Dashboard de performance operacional (proxies de custo / fila / pátio)
# PERFORMANCE_CUSTO_MINUTO_PROXY=0.05
# PERFORMANCE_FILA_GARGALO_LIMITE=15
# PERFORMANCE_PATIO_CAPACIDADE_ESTIMADA=200

# Opcional: seed (prisma db seed)
# SEED_ADMIN_EMAIL=admin@rltransportes.com
# SEED_ADMIN_PASSWORD=Admin@123

# NFS-e — IPM / Atende.Net (Navegantes-SC). Nunca versionar senha real.
# NFSE_IPM_SENHA=
# NFSE_IPM_BASE_URL=https://ws-navegantes.atende.net:7443/?pg=rest&service=WNERestServiceNFSe
# NFSE_IPM_PRESTADOR_CNPJ=27692077000126
# NFSE_IPM_PRESTADOR_TOM=8221
# NFSE_IPM_MUNICIPIO_IBGE=4211306
# Tag do indicador de cancelamento no XML (ex.: tipo); alinhe ao retorno do portal.
# NFSE_IPM_TAG_CANCEL=tipo

# GRC / Compliance (Fase 13): supervisor por e-mail (vírgula), igual conceito RH_PERF_SUPERVISOR_EMAILS
# GRC_SUPERVISOR_EMAILS=supervisor@empresa.com
# Limiar OCR portaria para incidente OPS-OCR-BACKLOG (default interno se omitido)
# GRC_OCR_BACKLOG_THRESHOLD=50
# Proxies numéricos só leitura (sem migrar outros módulos)
# GRC_RH_AUSENCIAS_PROXY=
# GRC_INCIDENTES_SEGURANCA_PROXY=
# GRC_EFICACIA_CONTROLE_DEFAULT=72
# GRC_PLANO_ACAO_CUSTO_ESTIMADO=0

# Integração / Mobilidade (Fase 14): API Key B2B formato key|clienteUuid (várias vírgula)
# INTEGRACAO_API_KEYS=
# Segredo POST interno /integracao/eventos e IoT (header X-Integracao-Interno)
# INTEGRACAO_INTERNO_SECRET=
# Rate limit por API Key / JWT cliente (req/min)
# INTEGRACAO_RATE_LIMIT_PER_MIN=120
# IP allowlist opcional (vírgula) para rotas de integração sensíveis
# INTEGRACAO_IP_ALLOWLIST=
# Webhook financeiro: assinatura HMAC opcional (canonical JSON fixo no código)
# INTEGRACAO_FINANCE_WEBHOOK_SECRET=
# SLA padrão em horas para métricas cliente-api
# INTEGRACAO_SLA_HORAS_PADRAO=72
# UUID de usuário existente para registrar auditoria de webhooks (opcional)
# INTEGRACAO_AUDITORIA_USER_ID=

# Observabilidade (Fase 15): proxies opcionais para health/dashboard sem alterar outros módulos
# OBS_WEBHOOK_QUEUE_DEPTH_PROXY=
# OBS_IA_EXEC_MS_PROXY=
# OBS_FISCAL_HEALTH_PROXY=
# OBS_RISCO_TEC_PROXY=

# IA preditiva (Fase 16): estatística local, sem APIs ML externas
# IA_PRED_DEMANDA_MESES_MAX=48
# IA_PRED_PATIO_CAPACIDADE=280
# IA_PRED_CLIMA_FATOR=1
# IA_PRED_ANOM_Z=2.5
# IA_PRED_HORA_UTIL_INI=6
# IA_PRED_HORA_UTIL_FIM=22
# IA_PRED_PERSIST_WEIGHTS=0

# Datahub (Fase 17): e-mails de GERENTE que operam Lake/ETL/Export/Quality/Obs (papel TI/Dados).
# GERENTE fora desta lista mantém só leitura BI + catálogo DW. ADMIN não precisa estar aqui.
# DATAHUB_TI_EMAILS=gerente.tech@suaempresa.com,ti.dados@suaempresa.com

# Plataforma / API pública B2B (Fase 18, sem migrations). Chaves em memória + Prisma read-only.
# Formato: apiKey|apiSecret|nome|tenantId|rpm|clienteId1,clienteId2 (último opcional; múltiplos clientes separados por ;).
# PLATAFORMA_API_CLIENTS=minha-pk|meu-secret|Parceiro A|default|120
# PLATAFORMA_GATEWAY_IP_ALLOWLIST=203.0.113.10,198.51.100.0
# PLATAFORMA_HMAC_SECRET=use-para-assinar-respostas-nfse-faturamento

# CX / Portais (Fase 20) — JWT dedicado opcional (default: anexa `:portal` ao segredo corporativo).
# PORTAL_JWT_SECRET=
# PORTAL_JWT_REFRESH_SECRET=
# PORTAL_JWT_EXPIRES_IN=1h
# PORTAL_JWT_REFRESH_EXPIRES_IN=7d
# Formato por linha: email|senha_em_texto|tenantId|PARCEIRO (opcional; default FORNECEDOR)
# CX_PORTAL_FORNECEDOR_SEED=fornecedor@local.test|SenhaForte1|default

# Cockpit NOC/TOC (Fase 22) — capacidade pátio no mapa e supervisores (e-mail, vírgula).
# COCKPIT_PATIO_CAPACIDADE=280
# COCKPIT_SUPERVISOR_EMAILS=supervisor.operacoes@empresa.com
# Proxies opcionais (read-only agregação)
# GRC_OCR_BACKLOG_PROXY=
# COCKPIT_RH_PROD_IA_PROXY=0.82
# COCKPIT_RH_GARGALO_PROXY=
# COCKPIT_TREND_IA_7D_PROXY=0
# COCKPIT_TREND_IA_30D_PROXY=0
# COCKPIT_TREND_IA_90D_PROXY=0

# Mobile hub (Fase 21) — JWT dedicado aos apps; default usa sufixo `:mobile` sobre JWT_SECRET.
# MOBILE_JWT_SECRET=
# MOBILE_JWT_REFRESH_SECRET=
# MOBILE_JWT_EXPIRES_IN=45m
# MOBILE_JWT_REFRESH_EXPIRES_IN=30d
# PIN opcional para rotas críticas (gate-in/out): header X-Mobile-Critical-Pin
# MOBILE_CRITICAL_PIN=
# Motoristas em memória (sem migration): email|senha|protocoloPadrao (várias linhas com ; ou newline)
# MOBILE_MOTORISTA_SEED=motorista@local.test|SenhaForte123|PROT-SEED-01
