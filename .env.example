# Copie para .env na raiz do monorepo
#
# Com Docker (npm run docker:up na raiz): usuário postgres, senha 123456, DB rl_transportes — igual a este URL.

DATABASE_URL=postgresql://postgres:123456@localhost:5432/rl_transportes

JWT_SECRET=defina_um_segredo_longo
JWT_REFRESH_SECRET=defina_outro_segredo_longo
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# Origens CORS (vírgula). Produção: domínio exato do portal / front.
# CORS_ORIGIN=https://app.empresa.com,https://portal.empresa.com
# TRUST_PROXY=1
# Recomendado atrás de reverse proxy / load balancer (X-Forwarded-For correto no rate limit).

# Limite global de pedidos por IP (default 100 / 15 min). Health check excluído da contagem.
# RATE_LIMIT_MAX=100

# Redis (rate limit login, cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Dashboard de performance operacional (proxies de custo / fila / pátio)
# PERFORMANCE_CUSTO_MINUTO_PROXY=0.05
# PERFORMANCE_FILA_GARGALO_LIMITE=15
# PERFORMANCE_PATIO_CAPACIDADE_ESTIMADA=200

# Opcional: seed (prisma db seed)
# SEED_ADMIN_EMAIL=admin@rltransportes.com
# SEED_ADMIN_PASSWORD=Admin@123

# NFS-e — IPM / Atende.Net (Navegantes-SC). Nunca versionar senha real.
# NFSE_IPM_SENHA=
# NFSE_IPM_BASE_URL=https://ws-navegantes.atende.net:7443/?pg=rest&service=WNERestServiceNFSe
# NFSE_IPM_PRESTADOR_CNPJ=27692077000126
# NFSE_IPM_PRESTADOR_TOM=8221
# NFSE_IPM_MUNICIPIO_IBGE=4211306
# Tag do indicador de cancelamento no XML (ex.: tipo); alinhe ao retorno do portal.
# NFSE_IPM_TAG_CANCEL=tipo
