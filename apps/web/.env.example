# API Nest (RL Transportes). Backend padrão: porta 3000; frontend Next: 3001.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Alinhar com backend CSRF_ENABLED=1 para enviar X-CSRF-Token nas mutações.
# NEXT_PUBLIC_CSRF_ENABLED=0

# Opcional: modo cookies HttpOnly para operadores (exige AUTH_HTTP_ONLY_COOKIES=1 no backend + CORS_ORIGIN com esta origem).
# NEXT_PUBLIC_AUTH_HTTP_ONLY=0

# No backend, inclua a origem do portal no CORS, por exemplo:
# CORS_ORIGIN=http://localhost:3001,http://localhost:3000
